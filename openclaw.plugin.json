{
  "id": "openclaw-procwatch",
  "name": "Process Watcher",
  "description": "Watch process output and trigger agent invocations on pattern matches",
  "version": "0.1.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "defaultPatterns": {
        "type": "array",
        "description": "Default patterns to watch for",
        "items": {
          "type": "object",
          "properties": {
            "regex": { "type": "string" },
            "label": { "type": "string" },
            "contextLines": { "type": "number" }
          },
          "required": ["regex", "label"]
        }
      },
      "throttleMs": {
        "type": "number",
        "description": "Throttle interval in ms between notifications (default 5000)"
      }
    }
  }
}
